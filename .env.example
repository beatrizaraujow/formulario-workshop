# ─── CORS ───────────────────────────────────────────────────────────────
# Origem(ns) do site publicado que podem chamar esta API. É origem EXATA
# (esquema + host, sem caminho, sem barra no fim): a landing e a /obrigado
# estão no mesmo domínio, então basta o domínio raiz.
# Separe por vírgula se tiver mais de uma (ex: domínio de preview + final).
# Deixe vazio durante o desenvolvimento para liberar qualquer origem.
ALLOWED_ORIGINS=https://carboneeducacao.com.br

# ─── Meta / Conversions API (Purchase de servidor) ──────────────────────
# O webhook do Stripe manda o Purchase pra Meta pelo servidor, deduplicado
# com o Purchase do navegador pelo event_id = session.id. Sem estas duas
# variáveis o envio fica DESLIGADO (não quebra nada, só não envia).
META_PIXEL_ID=1485981586008477
# Gerenciador de Eventos > seu Pixel > Configurações > Gerar token de acesso.
# Trate como senha: só no servidor (Vercel), NUNCA no componente do Framer.
META_CAPI_TOKEN=
# TEMPORÁRIO: enquanto testa, cole aqui o test_event_code do Gerenciador de
# Eventos (aba "Testar eventos") pra confirmar o recebimento SEM contar como
# conversão real. REMOVA esta variável quando for pra produção.
META_TEST_EVENT_CODE=
# Opcionais (têm padrão): página de retorno e versão da Graph API.
# META_EVENT_SOURCE_URL=https://carboneeducacao.com.br/obrigado-workshop
# META_GRAPH_VERSION=v21.0

# ─── Admin (reenvio/backfill do Purchase) ───────────────────────────────
# Segredo pra rota /api/admin/capi-resend (reenvio manual e backfill, ex: a
# compra da Patrícia). Sem ADMIN_TOKEN a rota fica desligada (503).
ADMIN_TOKEN=

# ─── Cron de reconciliação do CAPI ──────────────────────────────────────
# O Vercel Cron (ver vercel.json) roda /api/cron/capi-reconcile 1x/dia e
# reenvia vendas pagas que ficaram sem o marcador capiSent (falha da Meta).
# O Vercel injeta este segredo como "Authorization: Bearer <CRON_SECRET>".
# Sem CRON_SECRET a rota fica fechada (401).
CRON_SECRET=

# ─── Google Sheets (via Apps Script — sem Google Cloud) ────────────────
# URL do Web App gerada ao publicar o Apps Script da planilha (veja README).
# Termina em /exec.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/SEU_DEPLOY_ID/exec

# ─── Supabase ───────────────────────────────────────────────────────────
# Dashboard > Project Settings > API.
# URL do projeto (ex: https://abcdefgh.supabase.co)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# SERVICE ROLE KEY — ignora o RLS e lê/escreve tudo no banco.
# Trate como senha: só no servidor (Vercel > Settings > Environment Variables).
# NUNCA use no componente do Framer, nem em variável NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# A "anon key" NÃO é usada por este projeto: o navegador nunca fala com o
# banco, só com /api. Não precisa configurar.

# ─── Stripe ─────────────────────────────────────────────────────────────
# Chave secreta (Dashboard > Developers > API keys). Use a "sk_test_..." em teste.
STRIPE_SECRET_KEY=sk_test_...
# Segredo do webhook (Dashboard > Developers > Webhooks > sua_url > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Opcional: ID de um Price já cadastrado no Stripe (Product catalog).
# Se não definir, a API cria o valor "na hora" usando as 3 variáveis abaixo.
STRIPE_PRICE_ID=
STRIPE_AMOUNT=9700
STRIPE_CURRENCY=brl
STRIPE_PRODUCT_NAME=Workshop Carbone
# Os métodos de pagamento NÃO vêm de env: o Checkout usa o que estiver habilitado em
# Settings > Payment methods no Dashboard da Stripe. Assim, quando o Pix for aprovado
# na conta, ele passa a aparecer sozinho — sem mexer no código e sem redeploy.
# Para onde o cliente vai depois de concluir o pagamento (return_url do modo embedded).
# NÃO coloque ?session_id= aqui: a API já anexa sozinha o session_id na URL, e é ele
# que a página de obrigado usa pra confirmar a compra antes de mandar o evento pro GTM.
STRIPE_SUCCESS_URL=https://carboneeducacao.com.br/obrigado-workshop
# STRIPE_CANCEL_URL não é mais usada: no modo embedded o pagamento acontece dentro da
# própria página, então não existe "cancelar e voltar" pro site do Stripe.
