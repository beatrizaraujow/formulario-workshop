# ─── CORS ───────────────────────────────────────────────────────────────
# Domínio(s) do site publicado no Framer que podem chamar esta API.
# Separe por vírgula se tiver mais de um (ex: domínio de preview + domínio final).
# Deixe vazio durante o desenvolvimento para liberar qualquer origem.
ALLOWED_ORIGINS=https://seu-site.framer.website

# ─── Google Sheets (via Apps Script — sem Google Cloud) ────────────────
# URL do Web App gerada ao publicar o Apps Script da planilha (veja README).
# Termina em /exec.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/SEU_DEPLOY_ID/exec

# ─── Stripe ─────────────────────────────────────────────────────────────
# Chave secreta (Dashboard > Developers > API keys). Use a "sk_test_..." em teste.
STRIPE_SECRET_KEY=sk_test_...
# Segredo do webhook (Dashboard > Developers > Webhooks > sua_url > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Opcional: ID de um Price já cadastrado no Stripe (Product catalog).
# Se não definir, a API cria o valor "na hora" usando as 3 variáveis abaixo.
STRIPE_PRICE_ID=
STRIPE_AMOUNT=9700
STRIPE_CURRENCY=brl
STRIPE_PRODUCT_NAME=Workshop Carbone
# Métodos de pagamento no Checkout, separados por vírgula. Pix depende de liberação
# na conta Stripe (Brasil). Comece com "card"; quando o Pix for aprovado, troque
# para "card,pix" e redeploy — sem mexer no código.
STRIPE_PAYMENT_METHODS=card
# Para onde o Stripe redireciona depois do pagamento (páginas no seu site do Framer)
STRIPE_SUCCESS_URL=https://seu-site.framer.website/obrigado
STRIPE_CANCEL_URL=https://seu-site.framer.website/inscricao
